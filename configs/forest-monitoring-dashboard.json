{
  "title": "Eastern Mau Forest Environmental Monitoring Dashboard",
  "version": "1.0",
  "author": "Mike Papayai Passiany",
  "description": "Temporal dashboard for monitoring 40 years of land cover change in the Eastern Mau Forest Reserve, Kenya. Integrates classified Landsat/Sentinel-2 imagery with NDVI time series.",
  "dataSources": {
    "lulcClassification": {
      "type": "imageService",
      "url": "https://services.arcgis.com/xxx/arcgis/rest/services/EasternMau_LULC/ImageServer",
      "epochs": [1984, 1986, 1995, 2002, 2014, 2024]
    },
    "ndviTimeSeries": {
      "type": "featureService",
      "url": "https://services.arcgis.com/xxx/arcgis/rest/services/NDVI_Stats/FeatureServer/0"
    },
    "studyBoundary": {
      "type": "featureService",
      "url": "https://services.arcgis.com/xxx/arcgis/rest/services/StudyArea/FeatureServer/0"
    },
    "changeDetection": {
      "type": "featureService",
      "url": "https://services.arcgis.com/xxx/arcgis/rest/services/ChangeMatrix/FeatureServer/0"
    }
  },
  "widgets": [
    {
      "type": "indicator",
      "title": "Forest Cover (2024)",
      "value": "25.15%",
      "trend": "+16.03% from 2014",
      "trendDirection": "positive",
      "icon": "tree",
      "position": {"row": 0, "col": 0, "width": 3, "height": 2}
    },
    {
      "type": "indicator",
      "title": "Barren Land",
      "value": "25.54%",
      "trend": "-2.88% from 2014",
      "trendDirection": "positive",
      "icon": "landscape",
      "position": {"row": 0, "col": 3, "width": 3, "height": 2}
    },
    {
      "type": "indicator",
      "title": "Study Period",
      "value": "40 Years",
      "subtitle": "1984 - 2024",
      "position": {"row": 0, "col": 6, "width": 3, "height": 2}
    },
    {
      "type": "indicator",
      "title": "Epochs Analyzed",
      "value": "6",
      "subtitle": "Landsat 5/7/8, Sentinel-2",
      "position": {"row": 0, "col": 9, "width": 3, "height": 2}
    },
    {
      "type": "map",
      "title": "Land Cover Classification",
      "basemap": "dark-gray-vector",
      "center": {"lat": -0.35, "lon": 35.75},
      "zoom": 11,
      "layers": [
        {
          "dataSource": "lulcClassification",
          "renderer": "classBreaks",
          "classes": [
            {"value": 1, "label": "Dense Forest", "color": "#006400"},
            {"value": 2, "label": "Barren Land", "color": "#D2B48C"},
            {"value": 3, "label": "Settlement", "color": "#FF0000"},
            {"value": 4, "label": "Grassland", "color": "#90EE90"},
            {"value": 5, "label": "Planted Farmland", "color": "#FFD700"}
          ]
        },
        {"dataSource": "studyBoundary", "renderer": "outline", "color": "#00ffcc"}
      ],
      "timeSlider": {"enabled": true, "field": "epoch_year"},
      "position": {"row": 2, "col": 0, "width": 8, "height": 8}
    },
    {
      "type": "lineChart",
      "title": "Forest Cover Trend (1984-2024)",
      "dataSource": "ndviTimeSeries",
      "categoryField": "year",
      "series": [
        {"field": "forest_pct", "label": "Dense Forest", "color": "#006400"},
        {"field": "barren_pct", "label": "Barren Land", "color": "#D2B48C"},
        {"field": "settlement_pct", "label": "Settlement", "color": "#FF0000"},
        {"field": "grassland_pct", "label": "Grassland", "color": "#90EE90"}
      ],
      "position": {"row": 2, "col": 8, "width": 4, "height": 4}
    },
    {
      "type": "pieChart",
      "title": "Current Land Cover Distribution",
      "dataSource": "lulcClassification",
      "filter": "epoch_year = 2024",
      "categoryField": "class_name",
      "valueField": "area_pct",
      "position": {"row": 6, "col": 8, "width": 4, "height": 4}
    },
    {
      "type": "serialChart",
      "title": "NDVI Mean by Epoch",
      "dataSource": "ndviTimeSeries",
      "categoryField": "year",
      "valueField": "mean_ndvi",
      "chartType": "bar",
      "color": "#22c55e",
      "position": {"row": 10, "col": 0, "width": 6, "height": 4}
    },
    {
      "type": "table",
      "title": "Change Detection Matrix",
      "dataSource": "changeDetection",
      "fields": ["from_class", "to_class", "area_ha", "change_pct"],
      "sortField": "area_ha",
      "sortOrder": "desc",
      "position": {"row": 10, "col": 6, "width": 6, "height": 4}
    }
  ],
  "theme": {
    "primary": "#22c55e",
    "background": "#0a1628",
    "surface": "#162032",
    "text": "#e2e8f0",
    "accent": "#00ffcc"
  }
}
