{
  "title": "Kenya Drone Operations Monitoring Dashboard",
  "version": "1.0",
  "author": "Mike Papayai Passiany",
  "description": "Real-time monitoring dashboard for drone flight operations, restriction zone compliance, and airspace management across Kenya",
  "dataSources": {
    "flightPlans": {
      "type": "featureService",
      "url": "https://services.arcgis.com/xxx/arcgis/rest/services/FlightPlans/FeatureServer/0",
      "refreshInterval": 30
    },
    "restrictionZones": {
      "type": "featureService",
      "url": "https://services.arcgis.com/xxx/arcgis/rest/services/RestrictionZones/FeatureServer/0"
    },
    "airports": {
      "type": "featureService",
      "url": "https://services.arcgis.com/xxx/arcgis/rest/services/Airports/FeatureServer/0"
    },
    "liveAircraft": {
      "type": "externalApi",
      "url": "https://opensky-network.org/api/states/all",
      "parameters": {
        "lamin": -5.0,
        "lomin": 33.5,
        "lamax": 5.5,
        "lomax": 42.0
      },
      "refreshInterval": 15
    }
  },
  "widgets": [
    {
      "type": "indicator",
      "title": "Active Flights",
      "dataSource": "flightPlans",
      "filter": "status = 'active'",
      "statistic": "count",
      "position": {"row": 0, "col": 0, "width": 3, "height": 2}
    },
    {
      "type": "indicator",
      "title": "Total Restriction Zones",
      "dataSource": "restrictionZones",
      "statistic": "count",
      "position": {"row": 0, "col": 3, "width": 3, "height": 2}
    },
    {
      "type": "indicator",
      "title": "Airports Monitored",
      "dataSource": "airports",
      "statistic": "count",
      "position": {"row": 0, "col": 6, "width": 3, "height": 2}
    },
    {
      "type": "indicator",
      "title": "Live Aircraft (ADS-B)",
      "dataSource": "liveAircraft",
      "statistic": "count",
      "position": {"row": 0, "col": 9, "width": 3, "height": 2}
    },
    {
      "type": "map",
      "title": "Drone Operations Map",
      "basemap": "dark-gray-vector",
      "center": {"lat": 0.5, "lon": 37.8},
      "zoom": 6,
      "layers": [
        {"dataSource": "restrictionZones", "renderer": "uniqueValue", "field": "source_type"},
        {"dataSource": "flightPlans", "renderer": "simple", "symbol": "polygon-outline"},
        {"dataSource": "airports", "renderer": "simple", "symbol": "airport-icon"},
        {"dataSource": "liveAircraft", "renderer": "rotation", "field": "heading"}
      ],
      "position": {"row": 2, "col": 0, "width": 8, "height": 8}
    },
    {
      "type": "pieChart",
      "title": "Zones by Type",
      "dataSource": "restrictionZones",
      "categoryField": "source_type",
      "statistic": "count",
      "colors": ["#ef4444", "#f97316", "#eab308", "#22c55e", "#818cf8"],
      "position": {"row": 2, "col": 8, "width": 4, "height": 4}
    },
    {
      "type": "barChart",
      "title": "Flight Status",
      "dataSource": "flightPlans",
      "categoryField": "status",
      "statistic": "count",
      "colors": {
        "draft": "#6b7280",
        "submitted": "#3b82f6",
        "approved": "#22c55e",
        "rejected": "#ef4444",
        "active": "#f59e0b",
        "completed": "#10b981"
      },
      "position": {"row": 6, "col": 8, "width": 4, "height": 4}
    },
    {
      "type": "list",
      "title": "Recent Flight Plans",
      "dataSource": "flightPlans",
      "fields": ["mission_name", "operator", "planned_date", "status"],
      "sortField": "planned_date",
      "sortOrder": "desc",
      "maxItems": 10,
      "position": {"row": 10, "col": 0, "width": 6, "height": 4}
    },
    {
      "type": "serialChart",
      "title": "Flights per Day (30 Days)",
      "dataSource": "flightPlans",
      "categoryField": "planned_date",
      "valueStatistic": "count",
      "period": "last30days",
      "position": {"row": 10, "col": 6, "width": 6, "height": 4}
    }
  ],
  "theme": {
    "primary": "#3b82f6",
    "background": "#0f172a",
    "surface": "#1e293b",
    "text": "#e2e8f0",
    "accent": "#f59e0b"
  },
  "sharing": {
    "access": "public",
    "allowExport": true
  }
}
